# 开发环境配置（本地开发使用）
NODE_ENV=development
PORT=3003
API_PREFIX=/api

# 数据库配置（本地 Docker）
DATABASE_URL=postgresql://wordstar:wordstar123@localhost:5432/wordstar_db?schema=public

# Redis 配置（本地 Docker）
REDIS_URL=redis://localhost:6379

# JWT 配置
JWT_SECRET=wordstar-super-secret-jwt-key-for-development-32chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=wordstar-super-secret-refresh-key-for-development
JWT_REFRESH_EXPIRES_IN=30d

# 前端地址（用于 CORS）
FRONTEND_URL=http://localhost:5173
