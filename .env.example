# 环境变量配置示例
# 复制此文件为 .env.development（本地开发）或 .env.production（腾讯云生产）

# ============================================
# 前端配置
# ============================================

# API 基础地址
# 本地开发: http://localhost:3002/api
# 腾讯云: https://your-domain.com/api
VITE_API_BASE_URL=http://localhost:3002/api

# 应用名称
VITE_APP_NAME=单词星：21天倒计时

# 是否开启调试模式
# 本地: true
# 生产: false
VITE_DEBUG=true

# ============================================
# 后端配置（仅后端 .env 文件需要）
# ============================================

# 服务器配置
NODE_ENV=development
PORT=3002
API_PREFIX=/api

# 数据库配置
# 本地: postgresql://wordstar:password@localhost:5432/wordstar_db
# 腾讯云: postgresql://wordstar:password@tencent-db-host:5432/wordstar_db
DATABASE_URL=postgresql://wordstar:your_password@localhost:5432/wordstar_db?schema=public

# Redis 配置
# 本地: redis://localhost:6379
# 腾讯云: redis://tencent-redis-host:6379
REDIS_URL=redis://localhost:6379

# JWT 配置（生产环境使用强密码，至少32位）
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-characters
JWT_REFRESH_EXPIRES_IN=30d

# 前端地址（用于 CORS）
# 本地: http://localhost:5173
# 腾讯云: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# 日志级别
# 可选: debug, info, warn, error
LOG_LEVEL=debug